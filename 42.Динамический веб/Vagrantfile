Vagrant.configure("2") do |config|
  # Единственная ВМ с именем DynamicWeb
  config.vm.define "DynamicWeb" do |node|
    node.vm.box = "ubuntu24-gold"

    # Хостнейм внутри ВМ
    node.vm.hostname = "DynamicWeb"

    # Проброс портов на localhost
    node.vm.network "forwarded_port", guest: 8081, host: 8081
    node.vm.network "forwarded_port", guest: 8082, host: 8082
    node.vm.network "forwarded_port", guest: 8083, host: 8083

    # Ресурсы ВМ
    node.vm.provider "virtualbox" do |vb|
      vb.memory = "2048"
      vb.cpus = "2"
      vb.customize ["modifyvm", :id, "--audio", "none"]
    end

    # 1. Shell-провижинер: создание swap, установка Ansible
    node.vm.provision "shell", inline: <<-SHELL
      # Swap-файл (1 ГБ)
      dd if=/dev/zero of=/swapfile bs=1M count=1024
      chmod 600 /swapfile
      mkswap /swapfile
      swapon /swapfile
      echo '/swapfile none swap sw 0 0' >> /etc/fstab

      apt update
      apt install -y ansible
    SHELL

    # 2. Ansible-local провижинер
    node.vm.provision "ansible_local" do |ansible|
      ansible.verbose = "vvv"                # подробный вывод (можно убрать)
      ansible.playbook = "provisioning/playbook.yml"
      ansible.become = true                   # выполнение с sudo
      ansible.install = false                 # Ansible уже установлен скриптом выше
      ansible.compatibility_mode = "2.0"
    end
  end
end